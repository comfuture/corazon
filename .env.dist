# Copy this file to .env and set each value for your local environment.
OPENAI_API_KEY=
CORAZON_PORT=13000
# Host state root used by Docker Compose.
# ${CORAZON_HOST_STATE_DIR}/.corazon -> /root/.corazon
# ${CORAZON_HOST_STATE_DIR}/.corazon-runtime -> /root/.corazon-runtime
# ${CORAZON_HOST_STATE_DIR}/.ssh -> /root/.ssh
# ${CORAZON_HOST_STATE_DIR}/chroma -> /chroma/chroma
# ${CORAZON_HOST_STATE_DIR}/.corazon/gh -> /root/.config/gh (via entrypoint symlink)
# ${CORAZON_HOST_STATE_DIR}/.corazon/gitconfig -> /root/.gitconfig (via entrypoint symlink)
CORAZON_HOST_STATE_DIR=./.docker-state
# Optional: override the host Codex home mounted read-only into /root/.codex-seed.
# Defaults to ${HOME}/.codex when unset.
# CORAZON_CODEX_HOST_DIR=/home/your-user/.codex
# Codex runtime client mode: app-server (default) | sdk
# CORAZON_CODEX_CLIENT_MODE=app-server
# Local without Docker: use `pnpm chroma:run` and set this to `http://127.0.0.1:8000`.
# Docker Compose: leave it unset to use the bundled `chroma` service.
# CORAZON_MEMORY_CHROMA_URL=http://127.0.0.1:8000
CORAZON_MEMORY_CHROMA_COLLECTION=mem0
CORAZON_MEMORY_SYNC_ENABLED=true
MEM0_TELEMETRY=false
# Workflow script sandbox (language: `typescript`/`python`) settings.
# Current provider support: `local` only.
# CORAZON_WORKFLOW_SCRIPT_SANDBOX_PROVIDER=local
# Script execution timeout in milliseconds (default: 60000).
# CORAZON_WORKFLOW_SCRIPT_TIMEOUT_MS=60000
# Script output cap in bytes (default: 256000, minimum: 1024).
# CORAZON_WORKFLOW_SCRIPT_MAX_OUTPUT_BYTES=256000
# Script source-size cap in bytes (default: 64000, minimum: 256).
# CORAZON_WORKFLOW_SCRIPT_MAX_SOURCE_BYTES=64000
# Script temporary workspace cap in bytes (default: 8388608, minimum: 4096).
# CORAZON_WORKFLOW_SCRIPT_MAX_TMP_BYTES=8388608
# Script containment mode: host (default), auto (graceful fallback), linux-strict (requires Linux prefix adapter).
# CORAZON_WORKFLOW_SCRIPT_CONTAINMENT_MODE=host
# Optional Linux containment preset profile.
# Supported values: none (default), systemd-user-scope, systemd-system-scope, bubblewrap-minimal.
# Profile runtime dependencies: systemd-user-scope/systemd-system-scope => `systemd-run`, bubblewrap-minimal => `bwrap`.
# This profile is ignored when CORAZON_WORKFLOW_SCRIPT_CONTAINMENT_LINUX_PREFIX is explicitly set.
# CORAZON_WORKFLOW_SCRIPT_CONTAINMENT_LINUX_PROFILE=none
# Linux-only containment launcher prefix as JSON string array.
# First token must resolve to an executable on PATH (or be an absolute executable path).
# Example: ["systemd-run","--scope","--user","--"] or ["bwrap","--unshare-all","--die-with-parent","--"].
# CORAZON_WORKFLOW_SCRIPT_CONTAINMENT_LINUX_PREFIX=["systemd-run","--scope","--user","--"]
# Comma-separated env allowlist injected into script runs (default: empty).
# CORAZON_WORKFLOW_SCRIPT_ENV_ALLOWLIST=MY_API_BASE_URL,MY_PUBLIC_TOKEN
# Optional Python runtime binary for `language: python` workflows.
# CORAZON_WORKFLOW_PYTHON_BIN=python3
# Optional: Chroma Cloud
# CORAZON_MEMORY_CHROMA_API_KEY=
# CORAZON_MEMORY_CHROMA_TENANT=
# CORAZON_MEMORY_CHROMA_DATABASE=
